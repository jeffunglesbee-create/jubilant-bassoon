# Exclude non-app files from Cloudflare Workers asset upload.
# These are docs, CI scripts, and dev tools — not part of the FIELD web app.

# Git internals — MUST be excluded (pack files grow large quickly)
.git

# Large documentation files
FIELD-CURRENT-STATE.md
STANDARDS.md
HANDOFF.md
COMMENTS.md

# Scripts directory
scripts

# CI directory
.github

# Outbox (data files)
outbox

# Test / config files
smoke.js
field_smoke.js
field_unit.js
layer2_review.js
viewport_smoke.js
field_browser.test.js
playwright.config.js
playwright.viewport.config.js
screenshot_probe.js
otw_diag_probe.js
layout_probe.js
package.json
package-lock.json
wrangler.jsonc
.assetsignore

# Dev dependencies (local only — not committed, but excluded just in case)
node_modules
