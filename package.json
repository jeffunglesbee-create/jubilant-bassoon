{
  "name": "jubilant-bassoon",
  "version": "1.0.0",
  "description": "FIELD — Global Sports Intelligence",
  "private": true,
  "scripts": {
    "prepare": "git config core.hooksPath scripts",
    "smoke": "node field_smoke.js",
    "smoke:ci": "node smoke.js index.html",
    "test": "node field_unit.js",
    "test:browser": "npx playwright test field_browser.test.js",
    "test:ios": "node tests/ios-safari-viewport.js",
    "test:android": "node tests/android-chrome-viewport.js",
    "lint": "eslint --plugin html index.html",
    "inventory": "node scripts/inventory.js",
    "audit-prompt-tags": "node scripts/audit-prompt-tag-array.js",
    "call-graph": "node scripts/call-graph.js",
    "audit-silent-catches": "node scripts/audit-silent-catches.js",
    "lint:fix": "eslint --plugin html --fix index.html"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "eslint": "^8.0.0",
    "eslint-plugin-html": "^8.0.0",
    "tree-sitter-css": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "web-tree-sitter": "^0.25.0",
    "webdriverio": "^9.0.0"
  },
  "overrides": {
    "tree-sitter-javascript": {
      "peerDependenciesMeta": {
        "tree-sitter": { "optional": true }
      }
    },
    "tree-sitter-css": {
      "peerDependenciesMeta": {
        "tree-sitter": { "optional": true }
      }
    }
  },
  "engines": {
    "node": ">=18"
  }
}
