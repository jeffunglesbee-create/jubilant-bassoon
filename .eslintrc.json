{
  "env": {
    "browser": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "rules": {
    "no-undef": "warn",
    "no-unused-vars": "off",
    "no-restricted-syntax": [
      "error",
      {
        "selector": "AssignmentExpression > MemberExpression.left[object.type=\"CallExpression\"][object.callee.type=\"MemberExpression\"][object.callee.property.name=\"getElementById\"]",
        "message": "Store result first: const el = getEl(id); if (el) el.property = value"
      },
      {
        "selector": "MemberExpression[object.type=\"CallExpression\"][object.callee.type=\"MemberExpression\"][object.callee.property.name=\"getElementById\"][property.name=/^(style|classList|innerHTML|textContent|value|checked)$/]",
        "message": "Store result first: const el = getEl(id); if (el) el.property"
      },
      {
        "selector": "CallExpression[callee.property.name=\"replace\"][arguments.0.type=\"Literal\"][arguments.0.regex.pattern=/^```/]",
        "message": "Use stripJsonFences(text) then extractJsonBlock(text) \u2014 Rule 20"
      }
    ],
    "no-sequences": "error",
    "no-restricted-syntax-warn": "off"
  },
  "globals": {
    "allData": "readonly",
    "espnScores": "readonly",
    "espnScoreTs": "readonly",
    "TODAY_ISO": "readonly",
    "MY_SERVICES": "readonly",
    "MY_TEAMS": "readonly",
    "FIELD_DEBUG": "readonly",
    "CLAUDE_PROXY_URL": "readonly",
    "FD_RELAY": "readonly",
    "OM_BASE": "readonly",
    "SR": "readonly",
    "BUNDLES": "readonly",
    "PRICES": "readonly",
    "ESPN_SPORTS": "readonly",
    "SOCCER_LEAGUES": "readonly",
    "FD_LEAGUE_MAP": "readonly",
    "ESPN_STANDINGS_MAP": "readonly",
    "ODDS_SPORT_MAP": "readonly",
    "DRAMA_HISTORY_KEY": "readonly",
    "RELAY_PRIMARY": "readonly",
    "RELAY_CUTOVER_DATE": "readonly",
    "teamNick": "readonly",
    "teamSlug": "readonly",
    "teamSlugPair": "readonly",
    "gameNetwork": "readonly",
    "shiftTime": "readonly",
    "parseMatchweek": "readonly",
    "espnPeriodLabel": "readonly",
    "isOutdoorVenue": "readonly",
    "getVenueCoords": "readonly",
    "wxAlert": "readonly",
    "wxDescription": "readonly",
    "wxIcon": "readonly",
    "wxWindDir": "readonly",
    "wxBadge": "readonly",
    "toImpliedNum": "readonly",
    "dramaTier": "readonly",
    "trimToCompleteSentence": "readonly",
    "stripJsonFences": "readonly",
    "extractJsonBlock": "readonly",
    "espnTeamMatch": "readonly",
    "ESPN_OT_PERIODS": "readonly",
    "getEl": "readonly",
    "$": "readonly",
    "$$": "readonly",
    "fieldFetch": "readonly",
    "forEachGame": "readonly",
    "allGamesFlat": "readonly",
    "findGameById": "readonly",
    "getDramaPeak": "readonly",
    "findEspnEntry": "readonly",
    "rankGamesByDrama": "readonly"
  },
  "plugins": [
    "html"
  ]
}