#!/bin/sh
# FIELD pre-commit hook — branch enforcement + smoke + unit tests + lint
# before every commit.
# Rule 16: --no-verify bypass requires [no-verify: reason] in commit message
#
# Branch check added 2026-07-02, ported from field-relay-nba's pre-commit
# hook (added there 2026-07-01 after two stray-branch incidents in one
# session despite explicit written instructions being ignored both times).
# jubilant-bassoon's own CLAUDE.md states the same policy ("Every commit
# goes directly to main. Never create a feature branch...") but never had
# the corresponding structural enforcement — this closes that gap.

BRANCH="$(git rev-parse --abbrev-ref HEAD)"
# Detached HEAD means git rebase/cherry-pick/bisect is in progress — skip
# branch check so rebase --exec amends (e.g. for signing) aren't blocked.
if [ "$BRANCH" = "HEAD" ]; then
  :  # rebase in progress — branch check skipped
elif [ "$BRANCH" != "main" ]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════╗"
  echo "║  COMMIT BLOCKED — not on main                            ║"
  echo "║  Current branch: $BRANCH"
  echo "║  This repo commits directly to main. See CLAUDE.md.       ║"
  echo "╚══════════════════════════════════════════════════════════╝"
  exit 1
fi

REPO="$(git rev-parse --show-toplevel)"
command -v node >/dev/null 2>&1 || { echo "⚠  node not found — skipping checks"; exit 0; }

echo ""
echo "📋 DIFF REVIEW (Rule 13):"
git diff --staged --stat
echo "   Check: new variable names, removed functions, changes to shared functions."
echo ""

# Fast SW_VERSION sync check — catches A190 mismatches before full smoke (< 0.1s)
_HTML_SWV=$(grep -m1 "const SW_VERSION = '" "$REPO/index.html" | sed "s/.*'\([^']*\)'.*/\1/")
_SW_SWV=$(grep -m1 "const SW_VERSION = '" "$REPO/sw.js" | sed "s/.*'\([^']*\)'.*/\1/")
if [ -n "$_HTML_SWV" ] && [ "$_HTML_SWV" != "$_SW_SWV" ]; then
  echo "❌  A190 SW_VERSION mismatch — commit blocked"
  echo "    index.html: '$_HTML_SWV'"
  echo "    sw.js:      '$_SW_SWV'"
  echo "    Fix: set sw.js SW_VERSION = '$_HTML_SWV' before committing"
  exit 1
fi

echo "🔄 Syncing src/legacy/field.js → index.html..."
node "$REPO/scripts/sync-source.mjs" >/dev/null 2>&1 && git add "$REPO/index.html"

echo "🔍 Smoke test (structural)..."
node "$REPO/smoke.js" "$REPO/index.html" >/dev/null 2>&1; SMOKE_S=$?

echo "🔍 Smoke test (per-day invariants)..."
node "$REPO/field_smoke.js" "$REPO/index.html" >/dev/null 2>&1; SMOKE_D=$?
# NOTE: field_smoke_daily.js (slate ACCURACY) is run by the DAILY-UPDATE workflow,
#       NOT here — code/doc commits must not be gated on today's slate config.
#       See STANDARDS.md → "Smoke Gate Architecture (2026-05-28)".

# Both gates must pass
[ $SMOKE_S -eq 0 ] && [ $SMOKE_D -eq 0 ]; SMOKE=$?

echo "🧪 Unit tests..."
node "$REPO/field_unit.js" >/dev/null 2>&1; UNIT=$?

echo "🔎 Lint (auto-fix pass)..."
"$REPO/node_modules/.bin/eslint" --plugin html --fix "$REPO/index.html" >/dev/null 2>&1 && git add "$REPO/index.html"

echo "🔎 Lint (ESLint — blocks on errors, not warnings)..."
LINT_OUT=$("$REPO/node_modules/.bin/eslint" --cache --plugin html "$REPO/index.html" 2>&1)
LINT_ERRORS=$(echo "$LINT_OUT" | grep -c " error ")
LINT=$( [ "$LINT_ERRORS" -eq 0 ] && echo 0 || echo 1 )

if [ $SMOKE -ne 0 ] || [ $UNIT -ne 0 ] || [ $LINT -ne 0 ]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════╗"
  echo "║  CHECKS FAILED — commit blocked                          ║"
  [ $SMOKE   -ne 0 ] && echo "║  ❌ Smoke (structural) — run: node smoke.js index.html  ║"
  [ $SMOKE_D -ne 0 ] && echo "║  ❌ Smoke (per-day)   — run: node field_smoke.js        ║"
  [ $UNIT  -ne 0 ] && echo "║  ❌ Units    — run: node field_unit.js                   ║"
  [ $LINT  -ne 0 ] && echo "║  ❌ Lint     — run: npm run lint  ($LINT_ERRORS error(s))$(printf '%*s' $((23 - ${#LINT_ERRORS})) '')║"
  echo "║                                                          ║"
  echo "║  Rule 16: bypass = git commit --no-verify                ║"
  echo "║           MUST include [no-verify: reason] in msg        ║"
  echo "╚══════════════════════════════════════════════════════════╝"
  [ $SMOKE   -ne 0 ] && node "$REPO/smoke.js" "$REPO/index.html" 2>&1 | tail -5
  [ $SMOKE_D -ne 0 ] && node "$REPO/field_smoke.js" "$REPO/index.html" 2>&1 | tail -5
  [ $UNIT  -ne 0 ] && node "$REPO/field_unit.js"  2>&1 | tail -5
  [ $LINT  -ne 0 ] && echo "$LINT_OUT" | grep " error " | head -5
  exit 1
fi

echo "✅ Branch + smoke + units + lint passed"
exit 0
